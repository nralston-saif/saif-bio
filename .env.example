# The app runs in open-access DEMO MODE (in-memory sample data, no login)
# unless this is explicitly set to true AND the Supabase vars below are set:
NEXT_PUBLIC_USE_SUPABASE=false

# Supabase (SAIF Bio project - separate from SAIF Ventures)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (acknowledgement letter email delivery)
RESEND_API_KEY=re_xxxxxxxx
LETTER_FROM_EMAIL=letters@saifbio.org

# Optional market data for stock contribution valuation estimates (server-only)
FMP_API_KEY=your-financial-modeling-prep-key

# Secret for the daily stock-price cron (GET /api/cron/stock-prices). Vercel Cron
# sends it as `Authorization: Bearer <CRON_SECRET>`. Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# Claude API key for auto-extracting expense fields from uploaded invoice PDFs
# (server-only). If unset, invoice upload still works but fields are entered by hand.
ANTHROPIC_API_KEY=sk-ant-...
